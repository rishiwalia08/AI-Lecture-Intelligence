APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# LLM backend: huggingface | openai | none
LLM_BACKEND=huggingface
# HF task/model defaults tuned for cleaner instruction following
HF_TASK=text2text-generation
HF_CHAT_MODEL=google/flan-t5-base

# Optional (needed only if LLM_BACKEND=openai or EMBED_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ASR
WHISPER_MODEL_SIZE=base
WHISPER_COMPUTE_TYPE=int8
# Optional language hint for non-English videos, e.g. hi, ur, en
WHISPER_LANGUAGE=

# Embeddings backend: sentence-transformers | openai
EMBED_BACKEND=sentence-transformers
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2

TOP_K_RETRIEVAL=6
CHUNK_MAX_CHARS=850
CHUNK_PAUSE_THRESHOLD_SEC=1.5
